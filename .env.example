# Service runtime
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
INTERNAL_API_KEY=

# Operations / recovery
AUTO_RECOVERY_ENABLED=true
RESTART_COMMAND=

# External REST callouts
EXTERNAL_API_BASE_URL=
EXTERNAL_API_KEY=
EXTERNAL_API_TIMEOUT_MS=10000

# Provider selections
PAYMENT_PROVIDER=stripe
NOTIFICATION_PROVIDER=sendgrid
STORAGE_PROVIDER=postgres
MEDIA_PROVIDER=s3
MAPS_PROVIDER=google-maps
AUTH_PROVIDER=oauth

# Payment credentials
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# Notification credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
MAILGUN_API_KEY=

# Storage credentials
FIREBASE_PROJECT_ID=
SUPABASE_URL=
MONGODB_URI=
POSTGRES_URL=
MYSQL_URL=
REDIS_URL=

# Cloud/media credentials
S3_BUCKET=
CLOUDINARY_CLOUD_NAME=

# Maps credentials
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# Auth credentials
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
FIREBASE_AUTH_PROJECT_ID=
